<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
        <message key="containsTab" value="文件包含 Tab 字符，请使用空格缩进"/>
    </module>

    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://|ftp://"/>
        <message key="maxLineLen" value="行长度超过 120 字符"/>
    </module>

    <module name="FileLength">
        <property name="max" value="2000"/>
        <message key="maxLen.file" value="文件长度超过 2000 行，请考虑拆分"/>
    </module>

    <module name="TreeWalker">
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="类名 ''{0}'' 必须使用 PascalCase 命名（大写字母开头）"/>
        </module>

        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$|^logger$"/>
            <message key="name.invalidPattern" value="常量 ''{0}'' 必须使用 UPPER_SNAKE_CASE 命名"/>
        </module>

        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="成员变量 ''{0}'' 必须使用 camelCase 命名"/>
        </module>

        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="局部变量 ''{0}'' 必须使用 camelCase 命名"/>
        </module>

        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <message key="name.invalidPattern" value="参数 ''{0}'' 必须使用 camelCase 命名"/>
        </module>

        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
            <message key="name.invalidPattern" value="包名 ''{0}'' 必须全部小写"/>
        </module>

        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$|^[a-z][a-zA-Z0-9]*_[a-zA-Z0-9_]*$"/>
            <message key="name.invalidPattern" value="方法名 ''{0}'' 必须使用 camelCase 命名（测试方法允许下划线）"/>
        </module>

        <module name="AbbreviationAsWordInName">
            <property name="ignoreFinal" value="false"/>
            <property name="ignoreStatic" value="false"/>
            <property name="allowedAbbreviationLength" value="3"/>
            <property name="allowedAbbreviations" value="XML,URL,HTTP,HTTPS,API,ID,UUID,JWT,DAO,DTO,VO"/>
        </module>

        <module name="AvoidStarImport">
            <property name="excludes" value="org.junit.jupiter.api.Assertions,org.mockito.Mockito"/>
            <message key="import.avoidStar" value="禁止使用通配符 import：{0}"/>
        </module>

        <module name="UnusedImports">
            <message key="import.unused" value="未使用的 import：{0}"/>
        </module>

        <module name="RedundantImport">
            <message key="import.redundant" value="冗余的 import：{0}"/>
        </module>

        <module name="NeedBraces">
            <property name="allowSingleLineStatement" value="true"/>
            <message key="needBraces" value="''{0}'' 语句必须使用大括号"/>
        </module>

        <module name="LeftCurly">
            <property name="option" value="eol"/>
        </module>

        <module name="RightCurly">
            <property name="option" value="same"/>
        </module>

        <module name="EmptyBlock">
            <property name="option" value="text"/>
            <message key="block.empty" value="空代码块需要注释说明或移除"/>
        </module>

        <module name="OneStatementPerLine">
            <message key="multiple.statements.line" value="每行只能有一条语句"/>
        </module>

        <module name="EmptyStatement">
            <message key="empty.statement" value="禁止空语句"/>
        </module>

        <module name="EqualsHashCode">
            <message key="equals.hashCode" value="equals 和 hashCode 必须成对出现"/>
        </module>

        <module name="SimplifyBooleanExpression">
            <message key="simplify.expression" value="简化布尔表达式，避免冗余的 true/false 比较"/>
        </module>

        <module name="SimplifyBooleanReturn">
            <message key="simplify.return" value="简化布尔返回，避免冗余的 if-else"/>
        </module>

        <module name="StringLiteralEquality">
            <message key="string.literal.equality" value="字符串比较必须使用 equals()，禁止使用 =="/>
        </module>

        <module name="NestedIfDepth">
            <property name="max" value="3"/>
            <message key="nested.if.depth" value="if 嵌套深度超过 3 层，请重构代码"/>
        </module>

        <module name="NestedTryDepth">
            <property name="max" value="3"/>
            <message key="nested.try.depth" value="try 嵌套深度超过 3 层，请重构代码"/>
        </module>

        <module name="MethodLength">
            <property name="max" value="150"/>
            <property name="countEmpty" value="false"/>
            <message key="maxLen.method" value="方法长度超过 150 行，请考虑拆分"/>
        </module>

        <module name="ParameterNumber">
            <property name="max" value="7"/>
            <message key="maxParam" value="方法参数超过 7 个，请考虑使用参数对象"/>
        </module>

        <module name="WhitespaceAround">
            <property name="allowEmptyConstructors" value="true"/>
            <property name="allowEmptyMethods" value="true"/>
            <property name="allowEmptyTypes" value="true"/>
            <property name="allowEmptyLoops" value="true"/>
        </module>

        <module name="UpperEll"/>
        <module name="ArrayTypeStyle"/>
        <module name="DefaultComesLast"/>
        <module name="FallThrough"/>
        <module name="MultipleVariableDeclarations"/>
        <module name="NoFinalizer"/>
        <module name="PackageDeclaration"/>
        <module name="ExplicitInitialization"/>

        <module name="SuppressionCommentFilter">
            <property name="offCommentFormat" value="CHECKSTYLE:OFF"/>
            <property name="onCommentFormat" value="CHECKSTYLE:ON"/>
        </module>
    </module>

    <module name="SuppressionFilter">
        <property name="file" value="${checkstyle.suppressions.file}" default="quality-configs/checkstyle-suppressions.xml"/>
        <property name="optional" value="true"/>
    </module>
</module>
