<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter xmlns="https://github.com/spotbugs/filter/3.0.0"
                xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0
                https://raw.githubusercontent.com/spotbugs/spotbugs/master/spotbugs/etc/findbugsfilter.xsd">

    <!-- ========== Lombok @Data 生成代码的误报排除 ========== -->

    <!-- entity 包：Lombok @Data 生成的 Date/集合字段 getter/setter 导致 EI_EXPOSE_REP -->
    <Match>
        <Class name="~com\.xuena\.supplier\.entity\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2,EI_EXPOSE_STATIC_REP2"/>
    </Match>

    <!-- vo 包：响应对象中的 Date/集合字段 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.vo\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- ========== Spring Boot 框架误报排除 ========== -->

    <!-- config 包：Spring 配置类中的冗余 null 检查 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.config\..*"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE"/>
    </Match>

    <!-- filter 包：过滤器中的冗余 null 检查 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.filter\..*"/>
        <Bug pattern="RCN_REDUNDANT_NULLCHECK_OF_NONNULL_VALUE,NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- controller 包：Spring 注入导致的返回值空检查 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.controller\..*"/>
        <Bug pattern="NP_NULL_ON_SOME_PATH_FROM_RETURN_VALUE"/>
    </Match>

    <!-- controller / service.impl 包：Spring 构造函数注入导致的 EI_EXPOSE_REP2 误报 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.(controller|service\.impl)\..*"/>
        <Bug pattern="EI_EXPOSE_REP2"/>
    </Match>

    <!-- ========== 项目特定排除 ========== -->

    <!-- GeneratePassword 工具类：独立工具类，排除所有检查 -->
    <Match>
        <Class name="~.*GeneratePassword.*"/>
    </Match>

    <!-- MyBatis Mapper 接口：动态代理实现，排除未实现方法检查 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.mapper\..*"/>
        <Bug pattern="NP_NONNULL_PARAM_VIOLATION,RC_REF_COMPARISON"/>
    </Match>

    <!-- ========== 性能误报排除 ========== -->

    <!-- StringBuilder 使用误报 -->
    <Match>
        <Bug pattern="SBSC_USE_STRINGBUFFER_CONCATENATION"/>
    </Match>

    <!-- ========== 已知安全模式的排除 ========== -->

    <!-- JWT 工具类：密钥处理是安全的 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.util\.JwtUtil"/>
        <Bug pattern="HARD_CODE_PASSWORD,MS_SHOULD_BE_FINAL"/>
    </Match>

    <!-- PasswordUtil：密码工具类的硬编码是测试用 -->
    <Match>
        <Class name="~com\.xuena\.supplier\.util\.PasswordUtil"/>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>

</FindBugsFilter>
